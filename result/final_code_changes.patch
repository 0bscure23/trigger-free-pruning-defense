+# ── Config repair: TF 5.x save_pretrained drops fields that 4.x needs ──
+
+def _looks_like_llama3(config_dict: dict) -> bool:
+    """Return True if the config looks like a Llama-3.x model."""
+    model_type = config_dict.get("model_type", "")
+    if model_type != "llama":
+        return False
+    # Llama-3.x uses a larger vocab and has rope_scaling with rope_type llama3
+    rope = config_dict.get("rope_scaling") or {}
+    if isinstance(rope, dict) and rope.get("rope_type") == "llama3":
+        return True
+    # Fallback: vocab size 128256 is unique to Llama-3 tokenizer
+    if config_dict.get("vocab_size") == 128256:
+        return True
+    return False
+
+
+# Fields that TF 5.x drops from the config when the model has them
+_ROPE_KEYS = ("rope_scaling", "rope_theta")
+
+
+def save_model_and_tokenizer_safe(model, tokenizer, output_dir: str) -> None:
+    """Save model+tokenizer, then repair config.json fields that TF 5.x corrupts.
+
+    TF 5.3.0 save_pretrained() mutates config.json:
+    1. Drops ``rope_scaling`` and ``rope_theta`` (moves them to ``rope_parameters``).
+    2. May flatten ``eos_token_id`` from list to scalar.
+
+    Repairs are applied conditionally based on what the source model config contains.
+    No Llama-family hardcoded values are forced onto other model architectures.
+    """
+    import json
+    from pathlib import Path
+
+    out = Path(output_dir)
+    out.mkdir(parents=True, exist_ok=True)
+
+    model.save_pretrained(str(out))
+    tokenizer.save_pretrained(str(out))
+
+    config_path = out / "config.json"
+    if not config_path.exists():
+        return
+
+    with open(config_path, "r") as f:
+        saved_cfg = json.load(f)
+
+    src_cfg = model.config.to_dict()
+    is_llama3 = _looks_like_llama3(src_cfg)
+    repaired = False
+
+    # 1. Restore rope fields if they exist in source but were dropped by TF 5.x
+    for key in _ROPE_KEYS:
+        src_val = src_cfg.get(key)
+        if src_val is None:
+            continue
+        if key not in saved_cfg:
+            saved_cfg[key] = src_val
+            repaired = True
+        elif saved_cfg.get(key) != src_val:
+            saved_cfg[key] = src_val
+            repaired = True
+
+    # 2. Remove TF5.x-only rope_parameters (redundant with rope_scaling, confuses TF 4.x)
+    if "rope_parameters" in saved_cfg:
+        del saved_cfg["rope_parameters"]
+        repaired = True
+
+    # 3. Remove bare "dtype" (TF5.x artifact; torch_dtype is the standard key)
+    if "dtype" in saved_cfg and "torch_dtype" in saved_cfg:
+        del saved_cfg["dtype"]
+        repaired = True
+
+    # 4. eos_token_id: restore list form only when source had it
+    src_eos = src_cfg.get("eos_token_id")
+    saved_eos = saved_cfg.get("eos_token_id")
+    if isinstance(src_eos, list) and len(src_eos) > 1:
+        # Source had a multi-token eos list — TF 5.x may have flattened it
+        if not isinstance(saved_eos, list) or saved_eos != src_eos:
+            saved_cfg["eos_token_id"] = list(src_eos)
+            repaired = True
+    elif is_llama3 and isinstance(src_eos, int) and isinstance(saved_eos, int):
+        # Both scalar — leave as-is (this is normal for some Llama-3 variants)
+        pass
+    elif not is_llama3:
+        # Non-Llama model — do not touch eos_token_id
+        pass
+
+    # 5. Fix tokenizer_config if tokenizer_class was written as TokenizersBackend
+    tok_cfg_path = out / "tokenizer_config.json"
+    if tok_cfg_path.exists():
+        with open(tok_cfg_path, "r") as f:
+            tok_cfg = json.load(f)
+        if tok_cfg.get("tokenizer_class") == "TokenizersBackend":
+            tok_cfg["tokenizer_class"] = "PreTrainedTokenizerFast"
+            with open(tok_cfg_path, "w") as f:
+                json.dump(tok_cfg, f, indent=2)
+
+    if repaired:
+        with open(config_path, "w") as f:
+            json.dump(saved_cfg, f, indent=2)
+
+
